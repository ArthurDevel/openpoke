# OpenPoke Configuration
# Copy this file to .env and fill in your API keys

# Required: OpenRouter API key for LLM access
# Get your key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required: Composio API key and Gmail auth config ID
# Get these from https://composio.dev/
COMPOSIO_API_KEY=your_composio_api_key_here
COMPOSIO_GMAIL_AUTH_CONFIG_ID=your_gmail_auth_config_id_here

# Optional: Server configuration
# OPENPOKE_HOST=0.0.0.0
# OPENPOKE_PORT=8001

# Optional: CORS configuration
# OPENPOKE_CORS_ALLOW_ORIGINS=*

# Optional: Documentation
# OPENPOKE_ENABLE_DOCS=1
# OPENPOKE_DOCS_URL=/docs

# Optional: LiveKit talk mode
# Set these to enable the LiveKit voice agent used by Talk mode.
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your_livekit_api_key_here
# LIVEKIT_API_SECRET=your_livekit_api_secret_here
# LIVEKIT_ROOM_PREFIX=openpoke
# LIVEKIT_AGENT_NAME=openpoke-voice-agent
# DEEPGRAM_API_KEY=your_deepgram_api_key_here
# OPENPOKE_SERVER_URL=http://localhost:8001
# LIVEKIT_STT_MODEL=deepgram/nova-3:en
# LIVEKIT_LLM_MODEL=openai/gpt-4.1-mini
# LIVEKIT_TTS_MODEL=aura-2-andromeda-en
